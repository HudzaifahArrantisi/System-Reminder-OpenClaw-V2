flowchart LR
  %% ===== Actors =====
  Dosen([Aktor: Dosen])
  Mahasiswa([Aktor: Mahasiswa])
  OpenClaw([Aktor: OpenClaw Scheduler])
  Telegram([Sistem Eksternal: Telegram Bot API])

  %% ===== System Boundary =====
  subgraph S["Reminder E-Learning System"]
    UC1([Login])
    UC2([Pilih Mata Kuliah & Pertemuan])
    UC3([Buat/Upload Tugas + Deadline])
    UC4([Simpan Tugas ke Database])
    UC5([Kirim Notifikasi Instan ke Telegram])

    UC6([Scheduler Cek Tugas Aktif])
    UC7([Hitung Rule Reminder H-3/H-2/H-1/H0])
    UC8([Cek Duplikasi di notification_log])
    UC9([Kirim Reminder ke Telegram])

    UC10([Lihat Tugas Aktif])
    UC11([Submit Tugas])
  end

  %% ===== Dosen Flow =====
  Dosen --- UC1
  Dosen --- UC2
  Dosen --- UC3
  UC3 -. include .-> UC4
  UC3 -. include .-> UC5

  %% ===== Mahasiswa Flow =====
  Mahasiswa --- UC1
  Mahasiswa --- UC2
  Mahasiswa --- UC10
  Mahasiswa --- UC11

  %% ===== OpenClaw Flow =====
  OpenClaw --- UC6
  UC6 -. include .-> UC7
  UC7 -. include .-> UC8
  UC8 -. include .-> UC9

  %% ===== External Output =====
  UC5 --- Telegram
  UC9 --- Telegram