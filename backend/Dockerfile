# ── Build stage ──
FROM golang:1.21-alpine AS builder

WORKDIR /app

# Copy dependency files dan download
COPY go.mod go.sum ./
RUN go mod download

# Copy source code dan build
COPY . .
RUN CGO_ENABLED=0 GOOS=linux go build -o server ./cmd/server/main.go

# ── Runtime stage ──
FROM alpine:3.19

WORKDIR /app
COPY --from=builder /app/server .

EXPOSE 8080

CMD ["./server"]
